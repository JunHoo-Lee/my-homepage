{
  "name": "my-homepage",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0 <23"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=4096 node scripts/next-runner.cjs dev --disable-source-maps",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 node scripts/next-runner.cjs build",
    "start": "NODE_OPTIONS=--max-old-space-size=4096 node scripts/next-runner.cjs start",
    "lint": "eslint app tests playwright.config.ts vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "katex": "^0.16.27",
    "lucide-react": "^0.560.0",
    "next": "^16.2.10",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.7"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "ws": "^8.21.0"
  }
}
